{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@plank/core#dev": {
      "dependsOn": ["@plank/db#build", "@plank/schema#build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    }
  }
}
