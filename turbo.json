{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputLogs": "errors-only"
    },
    "@plank/core#dev": {
      "dependsOn": ["@plank/db#build", "@plank/schema#build"],
      "cache": false,
      "persistent": true,
      "outputLogs": "full"
    },
    "@plank/admin#dev": {
      "cache": false,
      "persistent": true,
      "outputLogs": "new-only"
    },
    "lint": {
      "outputs": []
    }
  }
}
